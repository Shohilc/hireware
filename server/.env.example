# Server Environment Variables
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/hirewave

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Google OAuth (optional — app works without it)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Upstash Redis (optional — falls back to in-memory cache)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Scraping
SCRAPE_INTERVAL_HOURS=6

# Apify Actor Configurations
APIFY_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=apify/linkedin-jobs-scraper
